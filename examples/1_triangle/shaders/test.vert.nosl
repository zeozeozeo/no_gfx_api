
Vertex :: struct
{
    pos: vec3,
    color: vec3
}

Data :: struct
{
    verts: []Vertex,
}

Output :: struct
{
    pos: vec4 @position,
    color: vec4 @output(0),
}

main :: (vert_id: uint @vert_id, data: ^Data @data) -> Output
{
    out: Output;
    out.pos = vec4(data.verts[vert_id].pos, 1.0);
    out.color = vec4(data.verts[vert_id].color, 1.0);
    return out;
}
