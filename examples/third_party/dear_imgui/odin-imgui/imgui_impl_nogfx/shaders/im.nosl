
Im_Draw_Vert :: struct
{
    pos: vec2,
    uv: vec2,
    col: uint,
}

Vert_Data :: struct
{
    verts: []Im_Draw_Vert,
    vert_offset: uint,
    scale: vec2,
    translate: vec2,
}

Vert_Output :: struct
{
    pos: vec4 @position,
    color: vec4 @io(0),
    uv: vec2 @io(1),
}

vert :: #vertex (data: ^Vert_Data @data, vert_id: uint @vert_id) -> Vert_Output
{
    vert_id_global := vert_id + data.vert_offset;
    vert := data.verts[vert_id_global];

    out: Vert_Output;
    out.color = uint_to_rgba8(vert.col);
    out.pos = vec4(vert.pos * data.scale + data.translate, 0, 1);
    out.uv = vert.uv;
    return out;
}

uint_to_rgba8 :: (v: uint) -> vec4
{
    return vec4(
        float(v & 0xFF),
        float((v >> 8)  & 0xFF),
        float((v >> 16) & 0xFF),
        float((v >> 24) & 0xFF),
    ) / 255.0;
}

Frag_Data :: struct
{
    tex_id: texture_id,
    sampler_id: sampler_id,
}

frag :: #fragment (data: ^Frag_Data @data, input: Vert_Output) -> vec4 @io(0)
{
    return input.color * texture_sample(data.tex_id, data.sampler_id, input.uv.xy);
}
