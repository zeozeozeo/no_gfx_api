
Vertex :: struct
{
    pos: vec4,
    color: vec4
}

Vert_Data :: struct
{
    verts: []Vertex,
}

Vert_Output :: struct
{
    pos: vec4 @position,
    color: vec4 @io(0),
}

vert :: #vertex (vert_id: uint @vert_id, data: ^Vert_Data @data) -> Vert_Output
{
    out: Vert_Output;
    out.pos = vec4(data.verts[vert_id].pos.xyz, 1.0);
    out.color = data.verts[vert_id].color;
    return out;
}

frag :: #fragment (input: Vert_Output) -> vec4 @io(0)
{
    return input.color;
}
